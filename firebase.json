{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
      {
        "source": "/sitemap.xml",
        "headers": [{ "key": "Content-Type", "value": "application/xml" }]
      },
      {
        "source": "/robots.txt",
        "headers": [{ "key": "Content-Type", "value": "text/plain" }]
      }
    ]
  }
}
